Output docs/assets/demos/pylings-demo.gif

Set Shell "bash"
Set FontSize 18
Set Width 1200
Set Height 760
Set Padding 16
Set Framerate 16
Set TypingSpeed 35ms

Type "pylings init --path /tmp/pylings-demo"
Enter
Sleep 1s

Type "cd /tmp/pylings-demo"
Enter
Sleep 300ms

Type "pylings list"
Enter
Sleep 1.5s

Type "pylings hint variables1"
Enter
Sleep 1.5s

Type "pylings"
Enter
Sleep 2s

Escape
Type@0ms "[15~"
Sleep 2s

Escape
Sleep 700ms

Escape
Type@0ms "OS"
Sleep 1.5s

Ctrl+Q
Sleep 500ms
